# Copy to .env and adjust as needed. Defaults work out-of-the-box for local dev.

# --- Kafka / Redpanda ---
KAFKA_BOOTSTRAP=localhost:9092
TRADES_TOPIC=crypto.trades

# --- Symbols to stream (Binance lowercase, comma-separated) ---
SYMBOLS=btcusdt,ethusdt,solusdt

# --- MinIO (S3-compatible data lake) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
LAKE_BUCKET=crypto-lake

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- LLM market-summary agent ---
# Leave OPENAI_API_KEY blank to use the built-in offline template summariser (no cost).
# Or set it to use OpenAI, or point OPENAI_BASE_URL at a local Ollama server.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
